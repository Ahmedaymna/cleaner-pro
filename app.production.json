{
  "expo": {
    "name": "Cleaner Pro",
    "slug": "cleaner-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cleaner-pro",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cleanerpro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#080C1A"
      },
      "package": "com.cleanerpro.app",
      "permissions": ["READ_EXTERNAL_STORAGE","WRITE_EXTERNAL_STORAGE","MANAGE_EXTERNAL_STORAGE"],
      "googleServicesFile": "./google-services.json"
    },
    "web": { "favicon": "./assets/images/icon.png" },
    "plugins": [
      ["expo-router", { "origin": "https://replit.com/" }],
      "expo-font",
      "expo-web-browser",
      ["react-native-google-mobile-ads", {
        "androidAppId": "ca-app-pub-6718038985057828~3801271527",
        "iosAppId": "ca-app-pub-6718038985057828~3801271527",
        "delayAppMeasurementInit": true,
        "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
      }]
    ],
    "experiments": { "typedRoutes": true, "reactCompiler": true }
  }
}
